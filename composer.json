{
    "name": "pixelcoda/search-platform",
    "description": "Accessible, API-first search platform with AI-assisted answers for TYPO3",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Pixelcoda",
            "email": "info@pixelcoda.com"
        }
    ],
    "support": {
        "issues": "https://github.com/CasianBlanaru/pixelcoda-typo3-search/issues",
        "source": "https://github.com/CasianBlanaru/pixelcoda-typo3-search"
    },
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "Pixelcoda\\Search\\": "apps/typo3-connector/Classes/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "echo 'PHP dependencies installed for TYPO3 connector'"
        ],
        "post-update-cmd": [
            "echo 'PHP dependencies updated for TYPO3 connector'"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
