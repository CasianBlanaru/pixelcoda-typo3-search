# ===========================
# TYPO3 Headless Search Configuration
# Better than T3AS - Production Ready
# ===========================

# API Configuration
PORT=8787
NODE_ENV=development
API_URL=http://localhost:8787

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://search_user:search_pass@localhost:5432/search_db
ENABLE_VECTOR_SEARCH=true

# Meilisearch Configuration
MEILI_URL=http://localhost:7700
MEILI_KEY=your_meilisearch_master_key

# LLM Provider Configuration (Choose one)
# ----------------------------------------
# Option 1: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Option 2: Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Option 3: Ollama (Local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Option 4: Hugging Face
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_MODEL=microsoft/DialoGPT-large
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Hybrid Retrieval Configuration
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_CROSS_ENCODER=true
ENABLE_RERANKING=true
HYBRID_BOOST_KEYWORD=0.5
HYBRID_BOOST_VECTOR=0.5

# Telemetry & Analytics
ENABLE_METRICS=true
ENABLE_TELEMETRY=true
TELEMETRY_SALT=random_salt_for_hashing

# Privacy & Security
ENABLE_PII_REDACTION=true
HMAC_SECRET=your_hmac_secret_key
IP_HASH_SALT=random_ip_salt
DATA_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true
GDPR_COMPLIANCE=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key
CORS_MAX_AGE=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# API Keys (for initial setup)
ADMIN_API_KEY=pc_admin_...
READ_API_KEY=pc_read_...
WRITE_API_KEY=pc_write_...

# TYPO3 Configuration
TYPO3_BASE_URL=https://your-typo3-site.com
TYPO3_API_ENDPOINT=/api/v1
TYPO3_WEBHOOK_SECRET=your_webhook_secret

# Worker Configuration
WORKER_ENABLED=true
WORKER_SCHEDULE_INDEX=0 */6 * * *
WORKER_SCHEDULE_CLEANUP=0 2 * * *
WORKER_SCHEDULE_ANALYTICS=0 3 * * *

# A/B Testing
ENABLE_AB_TESTING=true
AB_TEST_COOKIE_NAME=search_variant
AB_TEST_DEFAULT_VARIANT=control

# Index Management
INDEX_STRATEGY=blue_green
ACTIVE_INDEX=blue
REINDEX_BATCH_SIZE=100
REINDEX_CONCURRENT_JOBS=3

# SSE Streaming
ENABLE_SSE_STREAMING=true
SSE_HEARTBEAT_INTERVAL=30000
SSE_CLIENT_TIMEOUT=300000

# Admin Console
ADMIN_CONSOLE_ENABLED=true
ADMIN_CONSOLE_PATH=/admin
ADMIN_CONSOLE_SESSION_SECRET=your_session_secret

# Monitoring & Observability
ENABLE_PROMETHEUS_METRICS=true
PROMETHEUS_PORT=9090
LOG_LEVEL=info
LOG_FORMAT=json

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_REDIS_URL=redis://localhost:6379

# Feature Flags
FEATURE_SYNONYM_MINING=true
FEATURE_AUTO_SUGGEST=true
FEATURE_SPELL_CHECK=true
FEATURE_FACETED_SEARCH=true
FEATURE_PERSONALIZATION=false

# Development/Debug
DEBUG_MODE=false
VERBOSE_LOGGING=false
DISABLE_AUTH=false