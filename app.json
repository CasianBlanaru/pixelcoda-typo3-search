{
  "name": "Pixelcoda Search Platform",
  "description": "Modern, API-first search platform with AI agents for TYPO3 and other CMS systems",
  "repository": "https://github.com/CasianBlanaru/typo3-search",
  "logo": "https://avatars.githubusercontent.com/u/pixelcoda",
  "keywords": ["search", "api", "typo3", "cms", "ai", "vector-search"],
  "stack": "heroku-24",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "NODE_ENV": {
      "description": "Node.js environment",
      "value": "production"
    },
    "PORT": {
      "description": "Port for the web server",
      "value": "8787"
    },
    "API_READ_KEY": {
      "description": "API key for read operations",
      "generator": "secret"
    },
    "API_WRITE_KEY": {
      "description": "API key for write operations", 
      "generator": "secret"
    },
    "CORS_ALLOWED_ORIGINS": {
      "description": "Allowed CORS origins",
      "value": "*"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:mini",
      "as": "DATABASE"
    },
    {
      "plan": "heroku-redis:mini",
      "as": "REDIS"
    }
  ],
  "scripts": {
    "postdeploy": "echo 'Deployment successful'"
  }
}
