{
    "name": "pixelcoda/sitepackage",
    "description": "TYPO3 sitepackage for Pixelcoda.",
    "type": "typo3-cms-extension",
    "version": "1.0.0",
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^14.3",
        "typo3/cms-fluid-styled-content": "^14.3",
        "typo3/cms-frontend": "^14.3"
    },
    "autoload": {
